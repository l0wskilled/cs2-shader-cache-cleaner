<Window x:Class="CS2ShaderCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="CS2 Shader Cache Cleaner" Height="450" Width="550" 
        Background="#1E1E1E" Foreground="#FFFFFF" SnapsToDevicePixels="True" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Header -->
        <TextBlock Text="CS2 Shader Cache Cleaner" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#00FFCC"/>

        <!-- Steam Folder Picker Row -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SteamPathTextBox" Height="30" VerticalContentAlignment="Center" 
                     Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#555555" Padding="5,0"/>
            <Button Grid.Column="1" TextBlock.FontWeight="Medium" Content="Browse..." Width="80" Margin="10,0,0,0" Click="BrowseButton_Click"
                    Background="#3A3A3A" Foreground="#FFFFFF" BorderThickness="0"/>
        </Grid>

        <!-- Start Button -->
        <Button Grid.Row="2" x:Name="StartButton" Content="Start Cache Cleansing" Height="40" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"
                Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0" Click="StartButton_Click"/>

        <!-- Status / Log Terminal Output -->
        <GroupBox Grid.Row="3" Header="Operation Log Status" Foreground="#A0A0A0" BorderBrush="#444444">
            <TextBox x:Name="LogTextBox" Margin="5" Background="#121212" Foreground="#00FF66" 
                     FontFamily="Consolas" FontSize="12" IsReadOnly="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
        </GroupBox>
    </Grid>
</Window>
