<Window x:Class="CS2ShaderCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 Shader Cleaner" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Header -->
        <TextBlock Text="CS2 Shader Cache Cleaner" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#00FFCC"/>

        <!-- CS2 Folder Picker Row -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Select your CS2 Installation Folder (e.g. steamapps\common\Counter-Strike Global Offensive):" 
                       Foreground="#A0A0A0" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CS2PathTextBox" Height="30" VerticalContentAlignment="Center" 
                         Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#555555" Padding="5,0"/>
                <Button Grid.Column="1" TextBlock.FontWeight="Medium" Content="Browse..." Width="80" Margin="10,0,0,0" Click="BrowseButton_Click"
                        Background="#3A3A3A" Foreground="#FFFFFF" BorderThickness="0"/>
            </Grid>
        </StackPanel>

        <!-- Warning Message -->
        <TextBlock Grid.Row="2" x:Name="SteamWarningText" 
                   Text="Steam.exe couldn't be detected. Please start Steam manually after cleaning." 
                   Foreground="#FF5555" 
                   Visibility="Collapsed" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10" />

        <!-- Start Button -->
        <Button Grid.Row="3" x:Name="StartButton" Content="Start Cache Cleansing" Height="40" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"
                Background="#007ACC" Foreground="#FFFFFF" BorderThickness="0" Click="StartButton_Click"/>

        <!-- Status / Log Terminal Output -->
        <GroupBox Grid.Row="4" Header="Operation Log Status" Foreground="#A0A0A0" BorderBrush="#444444">
            <TextBox x:Name="LogTextBox" Margin="5" Background="#121212" Foreground="#00FF66" 
                     FontFamily="Consolas" FontSize="12" IsReadOnly="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
        </GroupBox>
    </Grid>
</Window>
